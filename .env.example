# --- Borb backend configuration ---
# Copy this file to `.env` and adjust to your environment.
# IMPORTANT: authority_mode is a backend start mode. It can NOT be changed by a
# prompt. Changing it requires a restart of the backend.

# Environment: development | production
BORB_ENV=development

# Authority mode: normal | authority
#   normal    -> Policy Engine evaluates every planned action (allow/confirm/block).
#   authority -> Full execution authority for local dev/testing. No confirmation,
#                no policy brake. Borb may do anything the OS process user may do.
BORB_AUTHORITY_MODE=normal

# Root directory Borb is allowed to operate in (used by the Policy Engine in
# normal mode). In authority mode this is effectively unrestricted.
BORB_WORKSPACE_ROOT=/home/user/project

# Capability switches (primarily relevant in normal mode).
BORB_ALLOW_SHELL=true
BORB_ALLOW_FILESYSTEM=true
BORB_ALLOW_NETWORK=true
BORB_ALLOW_PROCESS_CONTROL=false
BORB_ALLOW_PACKAGE_INSTALL=false
BORB_ALLOW_SUDO=false

# Audit logging
BORB_AUDIT_LOG=true
BORB_AUDIT_LOG_FILE=

# --- LLM provider configuration ---
# Provider: ollama | openai
BORB_LLM_PROVIDER=ollama
BORB_LLM_MODEL=llama3.1
BORB_LLM_TEMPERATURE=0.2
BORB_LLM_TIMEOUT=120

# Ollama (local)
BORB_OLLAMA_BASE_URL=http://localhost:11434

# OpenAI-compatible provider (OpenAI, vLLM, LM Studio, ...)
BORB_OPENAI_BASE_URL=https://api.openai.com/v1
BORB_OPENAI_API_KEY=

# Agent loop
BORB_AGENT_MAX_STEPS=6
BORB_SHELL_TIMEOUT=120

# --- Diary ---
# Borb keeps a daily diary. At BORB_DIARY_TIME (local server time) he reflects on
# the day; the entry is saved as `YYYYMMDD_Borb_Diary_Entry.md` in BORB_DIARY_DIR
# and the live conversation context is cleared afterwards (fresh start).
BORB_DIARY_ENABLED=true
BORB_DIARY_TIME=21:00
BORB_DIARY_DIR=~/Borb_Diary

# Server
BORB_HOST=127.0.0.1
BORB_PORT=8000
